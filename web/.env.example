# =====================================================================
# Webapp CCD (Coordenadoria de Controle de Decisões) — backend FastAPI
# Copie para web/.env e preencha. NÃO commitar o .env.
# =====================================================================

# --- SQL Server (TCE-RN ControleExterno) ---
# Bancos usados pelos módulos:
#   BdDIP   -> auth (Usuarios/TokensRenovacao), tabelas FRAP* e tabelas CGAD (Obrigacao, Recomendacao, NER*, Extracao...)
#   processo, BdSIAIPessoal/BdSIAI, BdCargaSigef{2023..2025} -> leitura
SQL_SERVER_USER=
SQL_SERVER_PASS=
SQL_SERVER_HOST=hostname\\InstanceName
SQL_SERVER_PORT=00000
SQL_SERVER_DATABASE=BdDIP
# SQL_SERVER_DRIVER=ODBC Driver 18 for SQL Server   # default; sobrescrever se usar Driver 17

# Nomes lógicos de DB para o módulo CGAD (todos via pyodbc)
SQL_SERVER_DB_PROCESSOS=processo
SQL_SERVER_DB_DECISOES=BdDIP
SQL_SERVER_DB_SIAI=BdSIAI

# --- Auth / JWT ---
JWT_SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# --- CORS / Redis ---
# Para acesso por outras máquinas da rede: adicione o IP da host (ex: http://172.16.4.200:3000)
CORS_ALLOWED_ORIGINS=http://localhost:3000
REDIS_URL=redis://localhost:6379

# --- Azure OpenAI (módulo CGAD: extração de obrigações/recomendações) ---
AZURE_OPENAI_API_KEY=
OPENAI_API_VERSION=2025-03-01-preview
AZURE_OPENAI_ENDPOINT=
# AZURE_OPENAI_DEPLOYMENT=gpt-4o

# --- API Extratos BB (módulo FRAP; preencher quando o credenciamento ICP-Brasil sair) ---
# BB_CLIENT_ID=
# BB_CLIENT_SECRET=
# BB_DEVELOPER_APPLICATION_KEY=
# BB_BASIC_AUTH=
# BB_CERT_PATH=
# BB_CERT_PASSWORD=

# --- Frontend (definir em web/frontend/.env.local) ---
# NEXT_PUBLIC_API_URL=http://localhost:8000
